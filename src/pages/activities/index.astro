---
import Layout from '../../layouts/Layout.astro';
import { TOUR_IMAGES } from '../../data/tours';
import { activities } from '../../data/activities';
---

<Layout title="Activities" description="Extra activities to enhance your Morocco tour — camel trekking, hot air balloon rides, cooking classes, Berber experiences, music, oasis walks and more.">
  <main>
    <!-- Hero -->
    <section class="relative flex items-center justify-center overflow-hidden" style="height: 350px;">
      <div class="absolute inset-0">
        <img src={TOUR_IMAGES.activitiesBanner} alt="Morocco cultural activities and experiences" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-black/50"></div>
      </div>
      <div class="relative z-10 text-center px-4">
        <h1 class="hero-title text-3xl sm:text-[36px] animate-on-scroll">ACTIVITIES</h1>
      </div>
    </section>

    <section class="py-16 bg-background">
      <div class="container-site">
        <div class="text-center mb-12 animate-on-scroll">
          <p class="section-subtitle">BREAK THE ROUTINE</p>
          <h2 class="text-[28px] sm:text-[32px] font-medium text-primary font-sans">
            Extra Activities for Your Tour
          </h2>
          <p class="text-[15px] text-primary/70 mt-4 max-w-2xl mx-auto">
            We offer a variety of extra activities that can be added to any of our tours to make your experience even more exciting and memorable.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {activities.map((activity, i) => (
            <a href={`/activities/${activity.slug}/`} class="block animate-on-scroll group" data-delay={i * 0.08}>
              <div class="relative overflow-hidden aspect-[4/3] bg-gray-200">
                <img
                  src={activity.image}
                  alt={activity.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
                <div class="tour-card-overlay absolute inset-0"></div>
                <div class="absolute bottom-0 left-0 right-0 p-5 z-10">
                  <h3 class="text-white text-lg font-medium mb-2">{activity.title}</h3>
                  <p class="text-white/80 text-[13px] leading-relaxed line-clamp-3">{activity.shortDescription}</p>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-12 animate-on-scroll">
          <p class="text-[15px] text-primary/70 mb-6 max-w-xl mx-auto">
            Interested in adding activities to your tour? Contact us and we will include them in your personalised itinerary.
          </p>
          <a href="/contact/" class="btn-submit" style="width: auto; display: inline-block;">
            CONTACT US
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
