---
import Layout from '../layouts/Layout.astro';
import { TOUR_IMAGES } from '../data/tours';
---

<Layout title="Blog" description="Coming soon! Travel tips, Morocco insights, cultural guides, and stories from the road by Siroco Tours.">
  <main>
    <!-- Hero -->
    <section class="relative h-[50vh] min-h-[350px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0">
        <img src={TOUR_IMAGES.chefchaouen} alt="Blue-washed buildings and narrow streets of Chefchaouen Morocco" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/50 to-black/60"></div>
      </div>
      <div class="relative z-10 text-center px-4">
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-white tracking-tight mb-4">Our Travel Blog</h1>
        <p class="text-white/80 text-lg max-w-2xl mx-auto">Stories, tips, and inspiration from Morocco and beyond.</p>
      </div>
    </section>

    <!-- Coming Soon -->
    <section class="py-24 bg-background">
      <div class="max-w-[600px] mx-auto px-4 sm:px-6 text-center">
        <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-6">
          <svg xmlns="https://thumbs.dreamstime.com/b/minimalist-bookmark-outline-icon-save-flag-line-art-vector-clean-line-art-illustration-vertical-flag-icon-used-412677366.jpg" class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>
          </svg>
        </div>
        <h2 class="font-display text-2xl font-bold tracking-tight mb-4">Coming Soon!</h2>
        <p class="text-muted-foreground leading-relaxed mb-8">
          We are preparing exciting travel tips, cultural insights, packing guides, and stories from the road. Check back soon for articles about Morocco's hidden gems, local cuisine, and travel planning advice.
        </p>
        <a href="/tours/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity">
          Explore Our Tours Instead
          <svg xmlns="https://thumbs.dreamstime.com/b/sleek-right-arrow-icon-rounded-rectangle-frame-minimalist-design-simple-modern-enclosed-rendered-flat-style-against-clean-388728363.jpg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </section>
  </main>
</Layout>
