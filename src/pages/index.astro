---
import Layout from '../layouts/Layout.astro';
import TourCard from '../components/TourCard.astro';
import CountUp from '../components/CountUp.astro';
import { tours, TOUR_IMAGES } from '../data/tours';

const featuredTours = [
  tours[0],  // Desert Trip
  tours[2],  // North to South
  tours[7],  // Desert Mountain Sea
  tours[9],  // Photography Tour
  tours[10], // Luxury Tour
  tours[11], // Revisit Morocco
];

const testimonials = [
  {
    name: 'Sarah & James',
    location: 'London, UK',
    text: 'An absolutely unforgettable experience. Our guide was incredibly knowledgeable, and every detail was perfectly arranged. The desert camp under the stars was the highlight of our trip.',
    tour: 'Imperial Cities and Desert',
  },
  {
    name: 'Miguel & Ana',
    location: 'Lisbon, Portugal',
    text: 'Siroco Tours exceeded all expectations. The private tour allowed us to go at our own pace and discover hidden gems. The Berber hospitality was heartwarming.',
    tour: 'Nature and Culture',
  },
  {
    name: 'David Cohen',
    location: 'New York, USA',
    text: "The Jewish Heritage tour was deeply moving and educational. Our guide's knowledge of Jewish-Moroccan history was remarkable. A truly meaningful journey.",
    tour: 'Jewish Heritage in Morocco',
  },
  {
    name: 'Claire Dupont',
    location: 'Paris, France',
    text: 'The photography tour was paradise for my camera! From the blue streets of Chefchaouen to sunrise over the dunes, every moment was frame-worthy. Highly recommend!',
    tour: 'Photography Tour',
  },
];

const valueProps = [
  { icon: 'users', title: 'Private & Personalized', description: 'Every tour is exclusively yours. Customize itineraries, pace, and activities to match your travel style.' },
  { icon: 'globe', title: 'Multilingual Guides', description: 'Expert local guides fluent in English, Spanish, French, and Portuguese ensure seamless communication.' },
  { icon: 'shield', title: 'Licensed & Insured', description: 'Government-licensed vehicles with AC and comprehensive insurance for your peace of mind.' },
  { icon: 'heart', title: 'Authentic Experiences', description: 'Go beyond tourist routes. Connect with Berber families, artisans, and local traditions.' },
];
---

<Layout title="Home">
  <main>
    <!-- Hero Section -->
    <section class="relative h-[90vh] min-h-[600px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0">
        <img src={TOUR_IMAGES.hero} alt="Golden Sahara desert dunes at sunset with camel caravan silhouette" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/60"></div>
      </div>
      <div class="relative z-10 max-w-[1200px] mx-auto px-4 sm:px-6 text-center">
        <div class="animate-on-scroll">
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6 leading-tight">
            Discover the <span class="text-primary">Magic</span> of Morocco
          </h1>
          <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8 leading-relaxed">
            Private, customizable tours through ancient medinas, vast Sahara dunes, majestic mountains, and vibrant cities — crafted exclusively for you.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/tours/" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg bg-primary text-primary-foreground font-semibold text-base hover:opacity-90 transition-opacity">
              Explore Our Tours
              <svg xmlns="https://upload.wikimedia.org/wikipedia/commons/thumb/e/e6/GreenButton_RightArrow.svg/3840px-GreenButton_RightArrow.svg.png" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <a href="/contact/" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg bg-white/15 backdrop-blur-sm text-white font-semibold text-base hover:bg-white/25 transition-colors border border-white/20">
              Request a Quote
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-secondary text-white py-8">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="font-display text-3xl sm:text-4xl font-bold text-primary"><CountUp end={12} suffix="+" /></div>
            <div class="text-sm text-white/70 mt-1">Unique Tours</div>
          </div>
          <div>
            <div class="font-display text-3xl sm:text-4xl font-bold text-primary"><CountUp end={15} suffix="+" /></div>
            <div class="text-sm text-white/70 mt-1">Years Experience</div>
          </div>
          <div>
            <div class="font-display text-3xl sm:text-4xl font-bold text-primary"><CountUp end={4} /></div>
            <div class="text-sm text-white/70 mt-1">Languages</div>
          </div>
          <div>
            <div class="font-display text-3xl sm:text-4xl font-bold text-primary"><CountUp end={100} suffix="%" /></div>
            <div class="text-sm text-white/70 mt-1">Private Tours</div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Preview -->
    <section class="py-20 bg-background">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="animate-on-scroll">
            <div class="relative aspect-[4/3] rounded-lg overflow-hidden bg-muted">
              <img src={TOUR_IMAGES.desertCamp} alt="Luxury Berber desert camp at night with lanterns and star-filled sky" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <div class="animate-on-scroll" data-delay="0.2">
            <span class="text-primary font-semibold text-sm uppercase tracking-widest">About Siroco Tours</span>
            <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-3 mb-6">
              Your Gateway to <span class="text-primary">Authentic</span> Morocco
            </h2>
            <p class="text-muted-foreground leading-relaxed mb-4">
              Based in Casablanca, Siroco Tours has been crafting unforgettable Moroccan journeys for over 15 years. We believe travel should be personal, meaningful, and transformative.
            </p>
            <p class="text-muted-foreground leading-relaxed mb-6">
              Every tour is private and fully customizable — from a 4-day desert escape to a 15-day deep exploration. Our multilingual guides share not just facts, but stories, traditions, and hidden corners that only locals know.
            </p>
            <a href="/about/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity">
              Learn More About Us
              <svg xmlns="https://i.etsystatic.com/23821301/r/il/7badc5/4897732962/il_570xN.4897732962_tur0.jpg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Tours -->
    <section class="py-20 bg-muted">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
        <div class="animate-on-scroll text-center mb-14">
          <span class="text-primary font-semibold text-sm uppercase tracking-widest">Our Tours</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-3">Explore Morocco Your Way</h2>
          <p class="text-muted-foreground mt-4 max-w-2xl mx-auto">From short desert getaways to comprehensive cross-country journeys — choose the adventure that speaks to you.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTours.map((tour, i) => (
            <TourCard tour={tour} delay={i * 0.1} />
          ))}
        </div>
        <div class="animate-on-scroll text-center mt-10">
          <a href="/tours/" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity">
            View All 12 Tours
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-20 bg-background">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
        <div class="animate-on-scroll text-center mb-14">
          <span class="text-primary font-semibold text-sm uppercase tracking-widest">Why Siroco Tours</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-3">Travel with Confidence</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {valueProps.map((prop, i) => (
            <div class="animate-on-scroll" data-delay={i * 0.1}>
              <div class="bg-card p-6 rounded-lg shadow-md hover:shadow-lg transition-all duration-300 text-center h-full">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    {prop.icon === 'users' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
                    {prop.icon === 'globe' && <><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></>}
                    {prop.icon === 'shield' && <><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></>}
                    {prop.icon === 'heart' && <><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></>}
                  </svg>
                </div>
                <h3 class="font-display font-bold mb-2">{prop.title}</h3>
                <p class="text-sm text-muted-foreground leading-relaxed">{prop.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Parallax Image -->
    <section class="relative h-[400px] overflow-hidden">
      <div class="absolute inset-0">
        <img src={TOUR_IMAGES.marrakech} alt="Vibrant Marrakech medina spice market with colorful spices and lanterns" class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-black/40"></div>
      </div>
      <div class="relative z-10 flex items-center justify-center h-full text-center px-4">
        <div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white tracking-tight mb-4">Ready for an Adventure?</h2>
          <p class="text-white/80 text-lg max-w-xl mx-auto mb-6">Every journey begins with a single step. Let us help you take yours through the wonders of Morocco.</p>
          <a href="/contact/" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity">
            Start Planning Your Trip
            <svg xmlns="https://upload.wikimedia.org/wikipedia/commons/thumb/8/88/Simpleicons_Interface_arrow-curve-pointing-to-right-direction.svg/500px-Simpleicons_Interface_arrow-curve-pointing-to-right-direction.svg.png?_=20160307131528" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="py-20 bg-muted">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
        <div class="animate-on-scroll text-center mb-14">
          <span class="text-primary font-semibold text-sm uppercase tracking-widest">Testimonials</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mt-3">What Travelers Say</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          {testimonials.map((t, i) => (
            <div class="animate-on-scroll" data-delay={i * 0.1}>
              <div class="bg-card p-6 rounded-lg shadow-md h-full flex flex-col">
                <div class="flex items-center gap-1 mb-4">
                  {[1,2,3,4,5].map(() => (
                    <svg xmlns="https://i.etsystatic.com/23821301/r/il/b430d8/6100068118/il_fullxfull.6100068118_r8ha.jpg" class="w-4 h-4 fill-primary text-primary" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  ))}
                </div>
                <p class="text-muted-foreground leading-relaxed italic flex-1">
                  "{t.text}"
                </p>
                <div class="mt-4 pt-4 border-t border-border">
                  <div class="font-semibold text-sm">{t.name}</div>
                  <div class="text-xs text-muted-foreground">{t.location} &bull; {t.tour}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-20 bg-secondary text-white">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 text-center">
        <div class="animate-on-scroll">
          <svg xmlns="https://i.ytimg.com/vi/c9KHUPGzgYg/sddefault.jpg" class="w-12 h-12 text-primary mx-auto mb-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
          </svg>
          <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight mb-4">Your Morocco Journey Awaits</h2>
          <p class="text-white/70 max-w-2xl mx-auto mb-8 text-lg">Tell us your dream trip and we will craft a personalized itinerary just for you. No obligations, no hidden fees — just honest travel advice.</p>
          <a href="/contact/" class="inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-primary text-primary-foreground font-semibold text-lg hover:opacity-90 transition-opacity">
            Get Your Free Quote
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
