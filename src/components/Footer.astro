---
---

<footer class="bg-secondary text-secondary-foreground">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-lg bg-primary flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
            </svg>
          </div>
          <span class="font-display text-lg font-bold tracking-tight text-white">Siroco Tours</span>
        </div>
        <p class="text-sm text-white/70 leading-relaxed">
          Private, customizable Morocco tours featuring desert adventures, imperial cities, Atlas Mountains, and authentic cultural experiences since 2010.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4">Quick Links</h3>
        <div class="space-y-2">
          <a href="/tours/" class="block text-sm text-white/70 hover:text-white transition-colors">Our Tours</a>
          <a href="/about/" class="block text-sm text-white/70 hover:text-white transition-colors">About Us</a>
          <a href="/contact/" class="block text-sm text-white/70 hover:text-white transition-colors">Contact</a>
        </div>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4">Contact</h3>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <svg xmlns="https://upload.wikimedia.org/wikipedia/commons/8/88/Map_marker.svg" class="w-4 h-4 text-primary mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-sm text-white/70">4 Rue Al Yarmouke, Casablanca 20100, Morocco</span>
          </div>
          <div class="flex items-center gap-3">
            <svg xmlns="https://i.etsystatic.com/16306938/r/il/fabaaa/1758823539/il_570xN.1758823539_eyjg.jpg" class="w-4 h-4 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:info@sirocotours.com" class="text-sm text-white/70 hover:text-white transition-colors">info@sirocotours.com</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 text-center">
      <p class="text-xs text-white/50">
        &copy; 2025 Siroco Tours – Société Mono Tours, S.A.R.L. All rights reserved.
      </p>
    </div>
  </div>
</footer>
