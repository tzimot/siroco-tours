---
import type { Tour } from '../data/tours';

interface Props {
  tour: Tour;
  delay?: number;
}

const { tour, delay = 0 } = Astro.props;
---

<div class="animate-on-scroll" data-delay={delay}>
  <a href={`/tours/${tour.slug}/`} class="group block h-full">
    <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 group-hover:-translate-y-1 h-full flex flex-col">
      <div class="relative aspect-[3/2] overflow-hidden bg-muted">
        <img
          src={tour.heroImage}
          alt={`${tour.name} - Morocco private tour`}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute top-3 right-3 px-3 py-1 rounded-full bg-black/60 backdrop-blur-sm text-white text-xs font-medium flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          {tour.duration}
        </div>
      </div>
      <div class="p-5 flex-1 flex flex-col">
        <h3 class="font-display text-lg font-bold tracking-tight group-hover:text-primary transition-colors">
          {tour.name}
        </h3>
        <div class="flex items-center gap-1 text-xs text-muted-foreground mt-1 mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          {tour.startLocation} → {tour.endLocation}
        </div>
        <p class="text-sm text-muted-foreground line-clamp-2 flex-1">
          {tour.shortDescription}
        </p>
        <div class="mt-4 flex items-center gap-1 text-primary font-semibold text-sm">
          View Details
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </div>
      </div>
    </div>
  </a>
</div>
